# Backend base URL (no trailing slash). The app appends /api/v1 and derives the
# WebSocket URL from this (http -> ws, https -> wss).
VITE_API_BASE_URL=http://localhost:8000

# Mapbox GL JS access token (https://account.mapbox.com/access-tokens/).
# Without it the map falls back to a simple coordinate picker.
VITE_MAPBOX_TOKEN=
