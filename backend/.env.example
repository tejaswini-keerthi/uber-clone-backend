# ---- App ----
APP_NAME=uber-clone-backend
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ---- PostgreSQL + PostGIS ----
POSTGRES_USER=uber
POSTGRES_PASSWORD=uber
POSTGRES_DB=uber
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Optional: set DATABASE_URL to fully override the assembled async URL.
# DATABASE_URL=postgresql+asyncpg://uber:uber@localhost:5432/uber

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---- JWT / Auth ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-in-production-please-use-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_RIDE_REQUESTS_TOPIC=ride-requests
KAFKA_ENABLED=true

# ---- Pricing engine (surge) ----
SURGE_API_BASE_URL=http://surge-api:8001
SURGE_REQUEST_TIMEOUT_SECONDS=2.0
SURGE_CACHE_TTL_SECONDS=30
# Fare = (BASE_FARE + distance_km * PER_KM_RATE) * surge_multiplier
BASE_FARE=2.50
PER_KM_RATE=1.20

# ---- Geo / matching ----
GEOHASH_PRECISION=6
DRIVER_SEARCH_RADIUS_METERS=5000
DEFAULT_CITY=San Francisco
